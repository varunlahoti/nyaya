# ------------------------------------------------------------------ #
# Nyaya environment. Copy to .env and fill in.
# The app boots with NOTHING set (heuristic fallbacks); set the keys
# below to get production-quality results.
# ------------------------------------------------------------------ #

# --- LLM: required for real issue-spotting and relevance ranking ---
# Provider: "openrouter" (default; cheap, strong models) or "anthropic".
LLM_PROVIDER=openrouter

# OpenRouter (default). Key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Reranker model (quality-sensitive). DeepSeek V3 = strong + very cheap.
LLM_MODEL=deepseek/deepseek-chat
# Parser model (lower stakes → cheapest fast model).
LLM_PARSER_MODEL=google/gemini-2.5-flash

# Alternative provider: Anthropic (set LLM_PROVIDER=anthropic).
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-opus-4-8

# --- Indian Kanoon API: required for the primary case-law retriever ---
# Licensed API token from https://api.indiankanoon.org/
INDIAN_KANOON_API_TOKEN=
INDIAN_KANOON_BASE_URL=https://api.indiankanoon.org

# --- Retrieval tuning ---
ENABLED_RETRIEVERS=["indian_kanoon","vector"]
CANDIDATE_CAP=25
RETRIEVER_TIMEOUT_SECONDS=6

# --- Embeddings (internal vector corpus). "hash" = dev fallback ---
EMBEDDINGS_PROVIDER=hash
# EMBEDDINGS_PROVIDER=voyage
# VOYAGE_API_KEY=
EMBEDDINGS_DIM=1024

# --- Vector corpus backend ---
#   none     -> Indian Kanoon only (spends IK credits per search)
#   memory   -> load seed corpus into RAM; runs searches OFFLINE, 0 IK credits
#   postgres -> pgvector corpus (production; needs DATABASE_URL)
# For dev/demo on the free IK credits, use "memory".
VECTOR_BACKEND=memory
SEED_CORPUS_PATH=data/seed_judgments.json

# --- Persistence / cache (Docker Compose sets these for you) ---
# DATABASE_URL=postgresql+asyncpg://nyaya:nyaya@db:5432/nyaya
# REDIS_URL=redis://redis:6379/0

# --- Auth (dev default is open; set True + a real secret for prod) ---
AUTH_REQUIRED=false
JWT_SECRET=change-me-in-production

# --- CORS (frontend origin) ---
CORS_ORIGINS=["http://localhost:3000"]

# --- Frontend ---
# Where the Next.js server proxies /api/* to (used by next.config.js).
API_BASE_URL=http://localhost:8000
