# TEMPLATE ONLY — no real keys here, and this file is safe to commit.
#
# On Streamlit Community Cloud: paste the real values into
#   App → Settings → Secrets   (they live only in the dashboard, never in git).
#
# For LOCAL testing with secrets: copy this to .streamlit/secrets.toml (which is
# git-ignored) and fill real values — or just use backend/.env.

OPENROUTER_API_KEY = "sk-or-..."
INDIAN_KANOON_API_TOKEN = "your-indian-kanoon-token"

# Password to access the app (protects your credits from public visitors).
APP_PASSWORD = "choose-a-strong-password"

# Optional overrides (defaults are fine):
# LLM_MODEL = "deepseek/deepseek-chat"
# LLM_PARSER_MODEL = "google/gemini-2.5-flash"
# MAX_QUERIES_PER_SEARCH = "3"
